# Normalize line endings for text files.
* text=auto eol=lf

# Explicitly mark common source/text types.
*.swift   text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.sh      text eol=lf
*.plist   text eol=lf
*.xcconfig text eol=lf
Makefile  text eol=lf

# Binary types (do not normalize).
*.png      binary
*.jpg      binary
*.jpeg     binary
*.icns     binary
*.dmg      binary
*.zip      binary
*.pdf      binary

# GitHub language stats: don't count vendored / generated content.
docs/release-notes/*.html linguist-generated=true
